{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKER"
  },
  "deploy": {
    "numReplicas": 1,
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE"
  },
  "services": {
    "backend": {
      "source": {
        "root": "backend"
      },
      "build": {
        "dockerfile": "Dockerfile.prod"
      }
    },
    "frontend": {
      "source": {
        "root": "frontend"
      },
      "build": {
        "dockerfile": "Dockerfile.prod"
      }
    }
  }
}
